# LLM Configuration
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MODEL_NAME=gemini-2.0-flash

# Hackathon-required variable name. For Gemini endpoint this can be left empty
# if GEMINI_API_KEY is set below.
HF_TOKEN=

# Recommended when API_BASE_URL points to Gemini:
GEMINI_API_KEY=

# Optional compatibility alias for other OpenAI-compatible endpoints:
OPENAI_API_KEY=

# Docker image name (when using from_docker_image)
LOCAL_IMAGE_NAME=crisis-comm-env

# Task selection
CRISIS_TASK=data-breach
