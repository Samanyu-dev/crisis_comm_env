# LLM Configuration
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
MODEL_FALLBACKS=

# Hackathon-required variable name. Primary key for HF Router.
HF_TOKEN=your_hf_token_here

# Optional when API_BASE_URL points to Gemini:
GEMINI_API_KEY=

# Optional compatibility alias for other OpenAI-compatible endpoints:
OPENAI_API_KEY=

# Docker image name (when using from_docker_image)
LOCAL_IMAGE_NAME=crisis-comm-env

# Task selection
CRISIS_TASK=data-breach
